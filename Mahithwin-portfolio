  function tick(){
    const full=lines[li];
    if(!deleting){
      el.textContent=full.slice(0,++ci);
      if(ci===full.length){ deleting=true; setTimeout(tick,1600); return; }
    } else {
      el.textContent=full.slice(0,--ci);
      if(ci===0){ deleting=false; li=(li+1)%lines.length; }
    }
    setTimeout(tick,deleting?28:48);
  }
  tick();
})();

