/* CUSTOM CURSOR */
(function(){
  const dot=document.getElementById('cursor-dot');
  const ring=document.getElementById('cursor-ring');
  if(!dot||!ring) return;
  let mx=window.innerWidth/2,my=window.innerHeight/2,rx=mx,ry=my;
